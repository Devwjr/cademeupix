APP_NAME="CadêMeuPix"
APP_ENV=production
APP_KEY=base64:gerar_com_php_artisan_key:generate
APP_DEBUG=false
APP_URL=https://seu-app.laravel.cloud

LOG_CHANNEL=stack
LOG_LEVEL=error

DB_CONNECTION=mysql
DB_HOST=pegar_no_painel_laravel_cloud
DB_PORT=3306
DB_DATABASE=pegar_no_painel_laravel_cloud
DB_USERNAME=pegar_no_painel_laravel_cloud
DB_PASSWORD=pegar_no_painel_laravel_cloud

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=public
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

MAIL_MAILER=smtp
MAIL_HOST=pegar_no_painel_laravel_cloud
MAIL_PORT=587
MAIL_USERNAME=pegar_no_painel_laravel_cloud
MAIL_PASSWORD=pegar_no_painel_laravel_cloud
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@cademeupix.com
MAIL_FROM_NAME="${APP_NAME}"

WHATSAPP_API_URL=https://api.whatsapp.com/send
WHATSAPP_ENABLED=true

PIX_KEY_TYPE=email
PIX_KEY=configurar_no_painel
PIX_MERCHANT_NAME=CadeMeuPix
PIX_MERCHANT_CITY=SAO PAULO

STRIPE_KEY=configurar_no_painel
STRIPE_SECRET=configurar_no_painel
STRIPE_WEBHOOK_SECRET=configurar_no_painel
STRIPE_PRICE_PROFESSIONAL=configurar_no_painel
STRIPE_PRICE_ENTERPRISE=configurar_no_painel
